#!/bin/bash
set -euo pipefail

echo "=== 1/6 Format check ==="
UNFORMATTED=$(gofmt -l . 2>&1 || true)
if [ -n "$UNFORMATTED" ]; then
  echo "Unformatted files:"
  echo "$UNFORMATTED"
  echo "Run: gofmt -w ."
  exit 1
fi

echo "=== 2/6 Lint ==="
golangci-lint run ./...

echo "=== 3/6 Vet ==="
go vet ./...

echo "=== 4/6 Go unit tests ==="
go test -race -count=1 ./...

echo "=== 5/6 Menu bar tests ==="
if command -v xcodegen >/dev/null 2>&1; then
  make menubar-test
else
  echo "Skipping menu bar tests: xcodegen not found"
fi

echo "=== 6/6 Build ==="
go build -o /dev/null ./cmd/fleet/

echo ""
echo "All checks passed."
